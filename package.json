{
  "name": "setup-evolve",
  "version": "0.1.0",
  "description": "GitHub Action to install the evolve CLI with supply-chain verification",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rollup --config rollup.config.js",
    "check": "biome check . && npm run lint:md",
    "check:fix": "biome check --write . && npm run lint:md -- --fix",
    "format": "prettier --write \"**/*.md\"",
    "lint:md": "markdownlint-cli2",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "all": "npm run check && npm run typecheck && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitwise-media-group/setup-evolve.git"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/cache": "6.0.1",
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1",
    "@actions/io": "3.0.2",
    "@actions/tool-cache": "4.0.0",
    "semver": "7.8.4",
    "sigstore": "5.0.0",
    "snappyjs": "0.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/node": "25.9.3",
    "@types/semver": "7.7.1",
    "@types/snappyjs": "0.7.1",
    "@vitest/coverage-v8": "4.1.8",
    "markdownlint-cli2": "0.22.1",
    "prettier": "3.8.4",
    "rollup": "4.61.1",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
